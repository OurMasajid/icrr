---
import type { JummahData } from '../lib/jummah';
import { jummahSameTopic } from '../lib/jummah';

interface Props { d: JummahData }
const { d } = Astro.props;
const same = jummahSameTopic(d);
---

{same ? (
  <Fragment>
    <div class="text-center">
      <span class="chip chip-gold text-base px-4 py-1.5">Today is Jumuʿah</span>
      <p class="uppercase text-xs tracking-widest text-emerald-200 mt-5">This Week's Khutbah</p>
      <h2 class="font-display text-3xl md:text-5xl font-bold text-white mt-2 leading-tight">"{d.first_khutbah_title}"</h2>
      <p class="text-emerald-50 text-xl mt-4">by <strong class="text-white">{d.first_khateeb}</strong></p>
    </div>
    <div class="flex justify-center gap-4 md:gap-6 mt-8">
      <div class="jummah-time-card">
        <p class="text-xs font-bold uppercase tracking-wider text-emerald-200">1st Jumuʿah</p>
        <p class="font-display text-3xl md:text-4xl text-white mt-1">{d.first_time}</p>
      </div>
      <div class="jummah-time-card">
        <p class="text-xs font-bold uppercase tracking-wider text-emerald-200">2nd Jumuʿah</p>
        <p class="font-display text-3xl md:text-4xl text-white mt-1">{d.second_time}</p>
      </div>
    </div>
    <div class="text-center mt-6">
      <p class="text-emerald-100/80 text-sm">Salah immediately after khutbah. Please arrive early.</p>
      <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-gold mt-4">Virtual Friday Donation Box</a>
    </div>
  </Fragment>
) : (
  <Fragment>
    <div class="text-center">
      <span class="chip chip-gold text-base px-4 py-1.5">Today is Jumuʿah</span>
      <p class="uppercase text-xs tracking-widest text-emerald-200 mt-5">This Week's Khutbahs</p>
    </div>
    <div class="flex flex-col sm:flex-row justify-center gap-4 md:gap-6 mt-8">
      <div class="jummah-time-card">
        <p class="text-xs font-bold uppercase tracking-wider text-emerald-200">1st Jumuʿah</p>
        <p class="font-display text-3xl md:text-4xl text-white mt-1">{d.first_time}</p>
        <h3 class="font-display text-lg md:text-xl font-bold text-white mt-3 leading-tight">"{d.first_khutbah_title}"</h3>
        <p class="text-emerald-50 mt-2">by <strong class="text-white">{d.first_khateeb}</strong></p>
      </div>
      <div class="jummah-time-card">
        <p class="text-xs font-bold uppercase tracking-wider text-emerald-200">2nd Jumuʿah</p>
        <p class="font-display text-3xl md:text-4xl text-white mt-1">{d.second_time}</p>
        <h3 class="font-display text-lg md:text-xl font-bold text-white mt-3 leading-tight">"{d.second_khutbah_title}"</h3>
        <p class="text-emerald-50 mt-2">by <strong class="text-white">{d.second_khateeb}</strong></p>
      </div>
    </div>
    <div class="text-center mt-6">
      <p class="text-emerald-100/80 text-sm">Salah immediately after khutbah. Please arrive early.</p>
      <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-gold mt-4">Virtual Friday Donation Box</a>
    </div>
  </Fragment>
)}
