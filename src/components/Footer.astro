---
interface Props {
  // The homepage footer has social icons, a longer blurb, an extra bottom
  // line, and a "Contact" quick link that the other pages' footer lacks.
  full?: boolean;
}
const { full = false } = Astro.props;
---

<footer class="footer pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-3">
        <span class="brand-mark"><img src="images/logo.png" alt="Islamic Center of Round Rock logo" class="brand-mark-img" width="44" height="44" /></span>
        <span class="font-display text-white text-lg">ICRR</span>
      </div>
      {full ? (
        <Fragment>
          <p class="text-sm mt-4 text-slate-400 leading-relaxed">
            The Islamic Center of Round Rock is a 501(c)(3) nonprofit serving Round Rock and surrounding communities since 2002.
          </p>
          <div class="flex items-center gap-2 mt-4">
            <a href="https://twitter.com/icrrmasjid" target="_blank" rel="noopener" class="social-pill" aria-label="Twitter"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 5.8c-.7.3-1.5.6-2.4.7.9-.5 1.5-1.3 1.8-2.3-.8.5-1.7.8-2.6 1A4.1 4.1 0 0 0 11.8 9c0 .3 0 .6.1.9A11.6 11.6 0 0 1 3 4.7a4.1 4.1 0 0 0 1.3 5.5c-.7 0-1.3-.2-1.9-.5v.1c0 2 1.4 3.6 3.3 4-.6.2-1.3.2-2 .1.6 1.6 2.1 2.8 4 2.9A8.3 8.3 0 0 1 2 18.4 11.6 11.6 0 0 0 8.3 20c7.5 0 11.6-6.2 11.6-11.6v-.5c.8-.6 1.5-1.3 2.1-2.1z"/></svg></a>
            <a href="https://www.facebook.com/RoundRockMasjid" target="_blank" rel="noopener" class="social-pill" aria-label="Facebook"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.1.4-2 2-2h2V2h-3c-3 0-5 1.8-5 5v3H6v4h3v8h4z"/></svg></a>
            <a href="https://www.youtube.com/@icrrmasjid" target="_blank" rel="noopener" class="social-pill" aria-label="YouTube"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22 8.2a3.2 3.2 0 0 0-2.3-2.3C17.8 5.4 12 5.4 12 5.4s-5.8 0-7.7.5A3.2 3.2 0 0 0 2 8.2 33.5 33.5 0 0 0 1.6 12 33.5 33.5 0 0 0 2 15.8a3.2 3.2 0 0 0 2.3 2.3c1.9.5 7.7.5 7.7.5s5.8 0 7.7-.5a3.2 3.2 0 0 0 2.3-2.3A33.5 33.5 0 0 0 22.4 12 33.5 33.5 0 0 0 22 8.2zM10 15.3V8.7l5.5 3.3-5.5 3.3z"/></svg></a>
          </div>
        </Fragment>
      ) : (
        <p class="text-sm mt-4 text-slate-400">A 501(c)(3) nonprofit serving Round Rock since 2002.</p>
      )}
    </div>

    <div>
      <h4>Quick Links</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="about.html">{full ? 'About Us' : 'About'}</a></li>
        <li><a href="programs.html">Programs</a></li>
        <li><a href="prayer-times.html">Prayer Times</a></li>
        <li><a href="events.html">Events</a></li>
        <li><a href="services.html">Services</a></li>
        {full && <li><a href="contact.html">Contact</a></li>}
      </ul>
    </div>

    <div>
      <h4>Visit</h4>
      <p class={full ? 'text-sm text-slate-400 leading-relaxed' : 'text-sm text-slate-400'}>
        1951 Hampton Ln<br/>
        Round Rock, TX 78664
      </p>
      <p class="text-sm text-slate-400 mt-3">
        <a href="tel:+15127303644">(512) 730-3644</a><br/>
        <a href="mailto:contact@roundrockmasjid.org">contact@roundrockmasjid.org</a>
      </p>
    </div>
  </div>

  {full ? (
    <div class="max-w-7xl mx-auto px-4 mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row gap-3 items-center justify-between text-xs text-slate-500">
      <p>© 2026 Islamic Center of Round Rock. All rights reserved.</p>
      <p>Built with care for the Ummah.</p>
    </div>
  ) : (
    <div class="max-w-7xl mx-auto px-4 mt-12 pt-6 border-t border-white/10 text-xs text-slate-500">© 2026 Islamic Center of Round Rock.</div>
  )}
</footer>
