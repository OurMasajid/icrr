---
interface Props {
  // Matches BaseLayout's `path` prop — the button hides itself on the
  // Donate page since a giant "Donate" button there is redundant.
  path?: string;
}
const { path } = Astro.props;
---

{path !== 'donate.html' && (
  <a href="donate.html" class="floating-donate btn btn-gold" aria-label="Donate to ICRR">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    <span>Donate</span>
  </a>
)}
