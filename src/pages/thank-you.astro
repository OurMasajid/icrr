---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Message Sent — Islamic Center of Round Rock"
  description="Your message has been received. We'll get back to you soon, insha'Allah."
  noindex
>
  <Topbar />
  <Nav />

  <section class="py-24 md:py-32">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="card-icon mx-auto" style="width:64px;height:64px;border-radius:50%">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h1 class="text-2xl md:text-3xl font-display font-bold mt-6 text-slate-900">Message Sent</h1>
      <p class="text-slate-600 mt-4 text-lg leading-relaxed">JazakAllahu khairan for reaching out. We've received your message and will get back to you as soon as we can, insha'Allah.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="index.html" class="btn btn-primary justify-center">Back to Home</a>
        <a href="prayer-times.html" class="btn btn-outline justify-center">Prayer Times</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
