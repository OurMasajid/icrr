---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — Islamic Center of Round Rock"
  description="Visit, call, email, or message ICRR — Round Rock's masjid since 2002."
  path="contact.html"
>
  <Topbar />
  <Nav active="contact" />

  <section class="page-header">
    <div class="max-w-7xl mx-auto px-4">
      <p class="crumbs"><a href="index.html">Home</a> / Contact</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3">Contact Us</h1>
      <p class="mt-4 max-w-2xl text-emerald-50/90">Visit us at the masjid, or send us a note — we'll get back to you as quickly as we can.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-5 gap-10">

      <aside class="lg:col-span-2 space-y-5">
        <div class="card">
          <span class="section-eyebrow">Visit</span>
          <p class="mt-3 font-semibold text-lg">Islamic Center of Round Rock</p>
          <p class="text-slate-600 mt-1">1951 Hampton Ln<br/>Round Rock, TX 78664</p>
          <a href="https://maps.google.com/?q=1951+Hampton+Ln+Round+Rock+TX+78664" target="_blank" rel="noopener" class="btn btn-outline mt-4">Get directions</a>
        </div>
        <div class="card">
          <span class="section-eyebrow">Reach Us</span>
          <p class="mt-3 text-slate-700"><strong>Office:</strong> <a class="text-brand" href="tel:+15127303644">(512) 730-3644</a></p>
          <p class="text-slate-700"><strong>Janāzah</strong> (9 am – 5 pm): <a class="text-brand" href="tel:+15126663389">(512) 666-3389</a> · <a class="text-brand" href="https://www.icgamuslimcemetery.org" target="_blank" rel="noopener">cemetery website</a></p>
          <p class="text-slate-700"><strong>Email:</strong> <a class="text-brand" href="mailto:contact@roundrockmasjid.org">contact@roundrockmasjid.org</a></p>
        </div>
        <div class="card bg-brand-soft border-brand">
          <span class="section-eyebrow">Office Hours</span>
          <ul class="mt-3 text-slate-700 space-y-1.5">
            <li>Mon–Fri · 10:00 AM – 6:00 PM</li>
            <li>Sat · 10:00 AM – 2:00 PM</li>
            <li>Sun · 9:00 AM – 1:00 PM (Sunday School)</li>
          </ul>
        </div>
      </aside>

      <div class="lg:col-span-3">
        <div class="card">
          <h2 class="font-display text-2xl">Send us a message</h2>
          <p class="text-slate-600 mt-2">Whether you have a question, need a service, or want to volunteer — we read every message.</p>
          <form name="contact" method="POST" action="/thank-you.html" data-netlify="true" class="mt-6 grid sm:grid-cols-2 gap-4">
            <input type="hidden" name="form-name" value="contact" />
            <div class="sm:col-span-1">
              <label class="font-medium text-slate-700">Name</label>
              <input name="name" class="contact-input mt-1.5" type="text" placeholder="Your name" required />
            </div>
            <div class="sm:col-span-1">
              <label class="font-medium text-slate-700">Email</label>
              <input name="email" class="contact-input mt-1.5" type="email" placeholder="you@example.com" required />
            </div>
            <div class="sm:col-span-2">
              <label class="font-medium text-slate-700">Subject</label>
              <select name="subject" class="contact-input mt-1.5">
                <option>General inquiry</option>
                <option>Volunteer</option>
                <option>Nikāḥ service</option>
                <option>Janāzah service</option>
                <option>Counseling</option>
                <option>Other</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <label class="font-medium text-slate-700">Message</label>
              <textarea name="message" class="contact-input mt-1.5" rows="6" placeholder="How can we help?" required></textarea>
            </div>
            <div class="sm:col-span-2 flex items-center justify-between gap-3">
              <p class="text-xs text-slate-500">We'll never share your information.</p>
              <button type="submit" class="btn btn-primary">Send message</button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="card overflow-hidden p-0">
        <iframe
          title="ICRR Map"
          class="w-full h-80 border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=1951+Hampton+Ln+Round+Rock+TX+78664&output=embed"></iframe>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
