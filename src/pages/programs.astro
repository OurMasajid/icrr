---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Programs — Islamic Center of Round Rock"
  description="Daily, weekly, monthly, and seasonal programs at ICRR — Quran, halaqas, youth nights, Sunday School, and more."
  path="programs.html"
>
  <Topbar />
  <Nav active="programs" />

  <section class="page-header">
    <div class="max-w-7xl mx-auto px-4">
      <p class="crumbs"><a href="index.html">Home</a> / Programs</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3">Programs</h1>
      <p class="mt-4 max-w-2xl text-emerald-50/90">Faith, family, and learning at every stage of life. Browse what's running each week.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-6">

      <article class="card">
        <span class="chip">Daily</span>
        <h2 class="font-display text-2xl mt-3">Five Daily Prayers</h2>
        <p class="mt-2 text-slate-600">All five obligatory prayers in congregation, with short Khatira reminders after Fajr and Isha.</p>
      </article>

      <article class="card">
        <span class="chip">Weekly · Monday</span>
        <h2 class="font-display text-2xl mt-3">Riyaad As-Saliheen</h2>
        <p class="mt-2 text-slate-600">A weekly halaqah after Isha covering the noble hadith of the Prophet ﷺ from Imam An-Nawawi's Riyāḍ aṣ-Ṣāliḥīn.</p>
      </article>

      <article class="card">
        <span class="chip">Weekly · Sunday</span>
        <h2 class="font-display text-2xl mt-3">Sunday School</h2>
        <p class="mt-2 text-slate-600">Structured Islamic education for children — Qurʾān, ʿaqīdah, fiqh, and Islamic history. Ages K–12.</p>
      </article>

      <article class="card">
        <span class="chip">Weekly</span>
        <h2 class="font-display text-2xl mt-3">Sisters' Halaqah</h2>
        <p class="mt-2 text-slate-600">A nurturing weekly circle for sisters covering Qurʾān, hadith, and contemporary issues.</p>
      </article>

      <article class="card">
        <span class="chip">Weekly</span>
        <h2 class="font-display text-2xl mt-3">Qurʾān Nāẓirah</h2>
        <p class="mt-2 text-slate-600">Tajwīd-focused Qurʾān reading classes for new and improving readers, taught in small groups.</p>
      </article>

      <article class="card">
        <span class="chip">Tarbiya</span>
        <h2 class="font-display text-2xl mt-3">Tarbiya Program</h2>
        <p class="mt-2 text-slate-600">Character-building circles for youth that go beyond memorization — focusing on adab, ākhirah, and identity.</p>
      </article>

      <article class="card">
        <span class="chip chip-gold">2nd Friday</span>
        <h2 class="font-display text-2xl mt-3">Girls Night Out</h2>
        <p class="mt-2 text-slate-600">A safe, fun monthly gathering for the masjid's young sisters — games, halaqahs, and snacks.</p>
      </article>

      <article class="card">
        <span class="chip chip-gold">3rd Friday</span>
        <h2 class="font-display text-2xl mt-3">Boys Night Out</h2>
        <p class="mt-2 text-slate-600">Brothers' monthly youth night — sports, lecture, and pizza in the masjid's gym space.</p>
      </article>

      <article class="card">
        <span class="chip">1st Friday</span>
        <h2 class="font-display text-2xl mt-3">Community Potluck</h2>
        <p class="mt-2 text-slate-600">After Maghrib on the first Friday of each month — featuring a guest speaker and homemade dishes from across the community.</p>
      </article>

      <article class="card">
        <span class="chip">Summer</span>
        <h2 class="font-display text-2xl mt-3">Summer Camp</h2>
        <p class="mt-2 text-slate-600">A multi-week summer program for kids — Qurʾān, Arabic, sports, arts, and field trips.</p>
      </article>

    </div>
  </section>

  <Footer />
</BaseLayout>
