---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page Not Found — ICRR"
  description="The page you're looking for could not be found."
  noindex
>
  <Topbar variant="svg" />

  <!-- Nav — bespoke markup unique to this page, kept as-authored rather than
       forced into the shared Nav component. -->
  <nav class="site-nav">
    <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="index.html" class="flex items-center gap-3">
        <span class="brand-mark"><img src="images/logo.png" alt="Islamic Center of Round Rock logo" class="brand-mark-img" width="44" height="44" /></span>
        <span class="font-display text-xl font-bold tracking-tight text-brand-deep">ICRR</span>
      </a>
      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-700">
        <li><a href="index.html" class="nav-link">Home</a></li>
        <li><a href="about.html" class="nav-link">About</a></li>
        <li><a href="programs.html" class="nav-link">Programs</a></li>
        <li><a href="prayer-times.html" class="nav-link">Prayer Times</a></li>
        <li><a href="events.html" class="nav-link">Events</a></li>
        <li><a href="services.html" class="nav-link">Services</a></li>
        <li><a href="contact.html" class="nav-link">Contact</a></li>
      </ul>
      <a href="contact.html" class="btn btn-brand hidden md:inline-flex">Get Involved</a>
      <button id="menuBtn" class="md:hidden p-2" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <div id="mobileMenu" class="mobile-menu md:hidden">
      <a href="index.html">Home</a>
      <a href="about.html">About</a>
      <a href="programs.html">Programs</a>
      <a href="prayer-times.html">Prayer Times</a>
      <a href="events.html">Events</a>
      <a href="services.html">Services</a>
      <a href="contact.html">Contact</a>
      <a href="contact.html" class="btn btn-brand justify-center mt-2">Get Involved</a>
    </div>
  </nav>

  <!-- 404 Content -->
  <section class="py-24 md:py-32">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-7xl md:text-9xl font-display font-bold text-brand-deep">404</p>
      <h1 class="text-2xl md:text-3xl font-display font-bold mt-6 text-slate-900">Page Not Found</h1>
      <p class="text-slate-600 mt-4 text-lg leading-relaxed">The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="index.html" class="btn btn-brand justify-center">Go Home</a>
        <a href="contact.html" class="btn btn-outline justify-center">Contact Us</a>
      </div>
      <div class="mt-12 pt-8 border-t border-slate-200">
        <p class="text-sm text-slate-500 mb-4">Or visit one of these pages:</p>
        <div class="flex flex-wrap justify-center gap-3 text-sm">
          <a href="prayer-times.html" class="text-brand hover:underline">Prayer Times</a>
          <span class="text-slate-300">|</span>
          <a href="programs.html" class="text-brand hover:underline">Programs</a>
          <span class="text-slate-300">|</span>
          <a href="events.html" class="text-brand hover:underline">Events</a>
          <span class="text-slate-300">|</span>
          <a href="services.html" class="text-brand hover:underline">Services</a>
          <span class="text-slate-300">|</span>
          <a href="about.html" class="text-brand hover:underline">About</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const btn = document.getElementById('menuBtn');
  const menu = document.getElementById('mobileMenu');
  btn && btn.addEventListener('click', () => menu.classList.toggle('open'));
  menu && menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => menu.classList.remove('open')));
</script>
