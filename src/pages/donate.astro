---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Donate — Islamic Center of Round Rock"
  description="Support ICRR's masjid construction, operations, education, and humanitarian programs. Give online, by Zelle, check, or in person — 100% tax-deductible."
  path="donate.html"
>
  <Topbar />
  <Nav active="donate" />

  <section class="page-header">
    <div class="max-w-7xl mx-auto px-4">
      <p class="crumbs"><a href="index.html">Home</a> / Donate</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mt-3">Donate</h1>
      <p class="mt-4 max-w-2xl text-emerald-50/90">Your Sadaqah Jariyah helps us expand our prayer space, fund educational programs, and serve those in need across our community.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <span class="section-eyebrow">Sadaqah Jariyah</span>
      <h2 class="section-title">Support the Masjid Construction & Operations</h2>
      <p class="mt-4 text-slate-600 max-w-2xl mx-auto">Every contribution — big or small — is a continuing charity that keeps the masjid open, growing, and serving Round Rock.</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-gold">Donate Now</a>
        <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-outline">Setup Monthly Giving</a>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4">
      <span class="section-eyebrow">Ways to Give</span>
      <h2 class="section-title mt-2">Choose What Works for You</h2>

      <div class="mt-8 grid md:grid-cols-2 gap-8">
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
          <h3 class="font-display text-2xl">Online</h3>
          <p class="text-slate-600 mt-2">Give a one-time or recurring donation by card or bank transfer through our secure online giving portal.</p>
          <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-primary mt-5">Donate Online</a>
        </article>

        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3 class="font-display text-2xl">Zelle</h3>
          <p class="text-slate-600 mt-2">Send directly from your bank's Zelle app — no fees, and the full amount reaches the masjid.</p>
          <p class="mt-3 font-semibold text-brand-deep">donateicrr@roundrockmasjid.org</p>
        </article>

        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M4 4l8 8 8-8"/></svg></div>
          <h3 class="font-display text-2xl">Check by Mail</h3>
          <p class="text-slate-600 mt-2">Make checks payable to <strong>Islamic Center of Round Rock</strong> and mail to:</p>
          <p class="mt-3 text-slate-700">1951 Hampton Ln<br/>Round Rock, TX 78664</p>
        </article>

        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3 class="font-display text-2xl">In Person</h3>
          <p class="text-slate-600 mt-2">Drop off cash or check at the front office during office hours, or give at the Jumu'ah collection.</p>
          <a href="contact.html" class="btn btn-outline mt-5">Office hours & directions</a>
        </article>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4">
      <span class="section-eyebrow">Where It Goes</span>
      <h2 class="section-title mt-2">Your Support at Work</h2>
      <div class="mt-8 grid sm:grid-cols-3 gap-5">
        <div class="card">
          <h3 class="font-display text-xl">Masjid Construction</h3>
          <p class="text-slate-600 mt-2">Expanding our prayer space to serve a growing community.</p>
        </div>
        <div class="card">
          <h3 class="font-display text-xl">Education</h3>
          <p class="text-slate-600 mt-2">Sunday School, youth programs, and Islamic classes for all ages.</p>
        </div>
        <div class="card">
          <h3 class="font-display text-xl">Humanitarian Aid</h3>
          <p class="text-slate-600 mt-2">Zakat and Sadaqah distributed to families in need through GAMRC.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="card bg-brand-soft border-brand text-center">
        <span class="section-eyebrow">Tax-Deductible</span>
        <p class="mt-3 text-slate-700 max-w-2xl mx-auto">Islamic Center of Round Rock is a registered 501(c)(3) nonprofit (EIN 35-2220327). All donations are tax-deductible to the extent allowed by law.</p>
        <p class="mt-3 text-slate-600">Questions about giving? <a class="text-brand font-semibold" href="contact.html">Contact us</a>.</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
