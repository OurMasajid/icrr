---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import JummahHero from '../components/JummahHero.astro';
import { getJummah } from '../lib/jummah';

const jummah = getJummah();

const allEvents = await getCollection('events');
const onHomepage = allEvents
  .filter((e) => e.data.show_on_homepage)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Islamic Center of Round Rock — ICRR"
  description="The Islamic Center of Round Rock (ICRR) serves the Round Rock community since 2002 with daily prayers, education, youth programs, and humanitarian assistance."
  ogDescription="A home for prayer, learning, and service — serving the Round Rock community since 2002."
  path=""
>
  <Fragment slot="og-extra">
    <meta property="og:locale" content="en_US" />
  </Fragment>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Mosque",
      "name": "Islamic Center of Round Rock",
      "alternateName": "ICRR",
      "url": "https://roundrockmasjid.org",
      "telephone": "+1-512-730-3644",
      "email": "contact@roundrockmasjid.org",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1951 Hampton Ln",
        "addressLocality": "Round Rock",
        "addressRegion": "TX",
        "postalCode": "78664",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 30.5217,
        "longitude": -97.6706
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "10:00", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "14:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "13:00" }
      ],
      "sameAs": [
        "https://www.facebook.com/RoundRockMasjid",
        "https://twitter.com/icrrmasjid",
        "https://www.youtube.com/@icrrmasjid"
      ],
      "foundingDate": "2002",
      "nonprofitStatus": "Nonprofit501c3",
      "description": "A 501(c)(3) nonprofit mosque serving Round Rock, TX since 2002 with daily prayers, education, youth programs, and humanitarian assistance."
    })} />
  </Fragment>

  <Topbar />
  <Nav active="home" home />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner max-w-7xl mx-auto px-4 py-10 lg:py-14">
      <div>
        <span class="chip chip-gold">Assalāmu ʿalaykum wa raḥmatullāh</span>
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold mt-3 leading-tight">
          Welcome to the <span class="text-yellow-300">Islamic Center</span> of Round Rock
        </h1>
        <p class="mt-3 text-emerald-50/90 text-base max-w-xl">
          A home for prayer, learning, and service to our neighbors — serving the Round Rock community since 2002.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="prayer-times.html" class="btn btn-gold">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Today's Prayer Times
          </a>
          <a href="programs.html" class="btn btn-outline" style="color:#fff;border-color:rgba(255,255,255,.55)">
            Explore Programs
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Prayer Times & Jummah -->
  <section class="py-10">
    <div class="max-w-5xl mx-auto px-4 flex flex-col lg:flex-row justify-center items-start gap-8">

      <!-- Jummah Banner — always visible; ordered before daily prayer on Fridays, after otherwise -->
      <div id="jummahHeroBanner" class="jummah-hero-card w-full lg:max-w-lg">
        <JummahHero d={jummah} />
      </div>

      <!-- Prayer times card -->
      <div class="prayer-card text-slate-900 w-full lg:max-w-lg">
        <div class="prayer-card-head">
          <div>
            <p class="text-xs uppercase tracking-widest text-emerald-100/80" data-today-label>Today · July 6, 2026</p>
            <h2 class="font-display text-2xl mt-1">Prayer Timings</h2>
          </div>
          <div class="text-right">
            <p class="text-xs text-emerald-100/80" data-hijri-day>Muharram 21</p>
            <p class="text-lg font-semibold" data-hijri-year>1448 H</p>
          </div>
        </div>
        <div class="prayer-head-label">
          <span>Prayer</span>
          <span>Adhan</span>
          <span class="end">Iqamah</span>
        </div>
        <div class="prayer-row">
          <span class="name">Fajr</span><span class="time" data-adhan="Fajr">5:17 AM</span><span class="iqamah" data-iqamah="Fajr">5:50 AM</span>
        </div>
        <div class="prayer-row">
          <span class="name">Sunrise</span><span class="time" data-adhan="Sunrise">6:34 AM</span><span class="iqamah" data-iqamah="Sunrise">—</span>
        </div>
        <div class="prayer-row">
          <span class="name">Zuhr</span><span class="time" data-adhan="Zuhr">1:36 PM</span><span class="iqamah" data-iqamah="Zuhr">2:00 PM</span>
        </div>
        <div class="prayer-row">
          <span class="name">Asr</span><span class="time" data-adhan="Asr">6:29 PM</span><span class="iqamah" data-iqamah="Asr">6:40 PM</span>
        </div>
        <div class="prayer-row">
          <span class="name">Maghrib</span><span class="time" data-adhan="Maghrib">8:37 PM</span><span class="iqamah" data-iqamah="Maghrib">8:42 PM</span>
        </div>
        <div class="prayer-row">
          <span class="name">Isha</span><span class="time" data-adhan="Isha">9:55 PM</span><span class="iqamah" data-iqamah="Isha">10:05 PM</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Upcoming Events Preview -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <span class="section-eyebrow">What's Happening</span>
          <h2 class="section-title">Upcoming Events</h2>
        </div>
        <a href="events.html" class="btn btn-primary">View all events →</a>
      </div>

      <div class="events-preview-scroll">
        {onHomepage.map((e) => <EventCard ev={e.data} homepage />)}
      </div>
    </div>
  </section>

  <!-- Welcome / About preview -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <span class="section-eyebrow">About ICRR</span>
        <h2 class="section-title">A community rooted in faith, learning, and service.</h2>
        <p class="mt-5 text-slate-600 leading-relaxed">
          Established in 2002 as a 501(c)(3) nonprofit, the Islamic Center of Round Rock is a place of worship, education, and connection. We open our doors to every Muslim and welcome our neighbors with open hearts.
        </p>
        <a href="about.html" class="btn btn-primary mt-6">Learn more about us</a>
      </div>
      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V10l7-5 7 5v11M9 21v-6h6v6"/></svg></div>
          <h3 class="font-semibold text-lg">Our Vision</h3>
          <p class="text-slate-600 mt-2 leading-relaxed">A vibrant, God-conscious community that radiates the mercy of Islam to all who live in Round Rock.</p>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          <h3 class="font-semibold text-lg">Our Mission</h3>
          <p class="text-slate-600 mt-2 leading-relaxed">To serve God through prayer, knowledge, family-centered programs, and humanitarian work.</p>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <h3 class="font-semibold text-lg">Imam & Shura</h3>
          <p class="text-slate-600 mt-2 leading-relaxed">Spiritual leadership and an elected Shura that guides the masjid's affairs with transparency.</p>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3 class="font-semibold text-lg">Volunteer</h3>
          <p class="text-slate-600 mt-2 leading-relaxed">Join the hands that keep this masjid running — every act of service is a sadaqah jariyah.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="py-20 bg-ink-soft">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center max-w-2xl mx-auto">
        <span class="section-eyebrow">Programs</span>
        <h2 class="section-title">Programs for every member of the family.</h2>
        <p class="mt-4 text-slate-600">From the first prayer of the day to youth gatherings, education, and humanitarian work — there's a place for you here.</p>
      </div>

      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <h3 class="font-display text-xl">Daily Programs</h3>
          <p class="text-slate-600 mt-2">Five daily prayers in congregation, with Khatira reminders after Fajr and Isha.</p>
        </article>
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></div>
          <h3 class="font-display text-xl">Educational Programs</h3>
          <p class="text-slate-600 mt-2">Quran Nazira, Sisters' Halaqah, Sunday School, Tarbiya, and Summer Camp.</p>
        </article>
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
          <h3 class="font-display text-xl">Youth Activities</h3>
          <p class="text-slate-600 mt-2">Girls Night Out (2nd Friday) & Boys Night Out (3rd Friday) every month.</p>
        </article>
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <h3 class="font-display text-xl">Monthly Programs</h3>
          <p class="text-slate-600 mt-2">Community potluck with a guest speaker on the 1st Friday of every month.</p>
        </article>
        <article class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 14 9l7 1-5 4 2 8-6-4-6 4 2-8-5-4 7-1z"/></svg></div>
          <h3 class="font-display text-xl">Spiritual Enrichment</h3>
          <p class="text-slate-600 mt-2">Riyaad As-Saliheen Monday sessions on the noble hadith of the Prophet ﷺ.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-10">
      <div>
        <span class="section-eyebrow">Services</span>
        <h2 class="section-title">Here when you need us.</h2>
        <p class="mt-4 text-slate-600">The masjid offers services for important life moments, with care and according to Islamic principles.</p>
        <a href="services.html" class="btn btn-primary mt-6">All services</a>
      </div>
      <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3 class="font-semibold">Funeral (Janazah)</h3>
          <p class="text-slate-600 mt-2">A death in the community? Call <a class="text-brand font-semibold" href="tel:+15126663389">(512) 666-3389</a> (9 am – 5 pm) for arrangements.</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <a href="tel:+15126663389" class="btn btn-primary">Call now</a>
            <a href="https://www.icgamuslimcemetery.org" target="_blank" rel="noopener" class="btn btn-outline">Cemetery website</a>
          </div>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3 class="font-semibold">Nikāḥ Service</h3>
          <p class="text-slate-600 mt-2">Marriage ceremonies officiated by the Imam according to Islamic principles.</p>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
          <h3 class="font-semibold">Free Medical Clinic</h3>
          <p class="text-slate-600 mt-2">In partnership with Eixsys Healthcare · Wednesdays, 6:30–7:30 PM.</p>
        </div>
        <div class="card">
          <div class="card-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3 class="font-semibold">Humanitarian Assistance</h3>
          <p class="text-slate-600 mt-2">ICRR is part of the Greater Austin Muslim Relief Committee (GAMRC), offering a Free Food Pantry partnership and financial assistance to families in need.</p>
          <p class="mt-3">If you need help, <a class="text-brand font-semibold" href="https://austinzakat.org/ApplyForHelp" target="_blank" rel="noopener">apply here</a> · <a class="text-brand font-semibold" href="https://austinzakat.org/PayZakatHere" target="_blank" rel="noopener">Pay Zakat here</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Donate / CTA -->
  <section id="donate" class="py-20 bg-ink-soft">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <span class="section-eyebrow">Sadaqah Jariyah</span>
      <h2 class="section-title">Support the Masjid Construction & Operations</h2>
      <p class="mt-4 text-slate-600 max-w-2xl mx-auto">Your contribution helps us expand our prayer space, fund educational programs, and serve those in need across our community.</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-gold">Donate Now</a>
        <a href="https://us.mohid.co/tx/austin/icrr/masjid/online/donation" target="_blank" rel="noopener" class="btn btn-outline">Setup Monthly Giving</a>
      </div>
    </div>
  </section>

  <Footer full />
</BaseLayout>

<script>
  import '../scripts/home.client.js';
</script>
<script>
  import '../scripts/prayer-times.client.js';
</script>
